# ---- Supabase (your own project) ----
# Build-time (client) — must be present when Vercel builds the app
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Runtime (server) — used by server routes / admin client
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=

# ---- Email (Resend) ----
RESEND_API_KEY=
# Verified sender, e.g. "Luxx Touch Aesthetics <noreply@luxxtouchaesthetics.com>"
EMAIL_FROM=
# Where the owner copy of booking receipts is sent
OWNER_EMAIL=luxxtouch1@gmail.com
# Public site URL — used for auth email links (signup confirm, password reset).
# Use your live www URL so confirmation emails never point at localhost.
VITE_SITE_URL=https://www.luxxtouchaesthetics.com
# Server-side copy (emails, unsubscribe links)
SITE_URL=https://www.luxxtouchaesthetics.com

# ---- Scheduled jobs (appointment reminders) ----
# Shared secret protecting /api/cron/reminders. Generate a long random string.
# Vercel Cron automatically sends it as "Authorization: Bearer <CRON_SECRET>".
# External schedulers can also pass it as ?secret=<CRON_SECRET>.
CRON_SECRET=
